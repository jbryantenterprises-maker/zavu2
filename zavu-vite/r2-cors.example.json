{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "https://your-domain.com",
          "https://your-project.pages.dev"
        ],
        "methods": [
          "PUT",
          "HEAD"
        ],
        "headers": [
          "Content-Type"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
